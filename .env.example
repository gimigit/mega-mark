# MegaMark — Agricultural Marketplace Environment Variables
# Copy this file to .env.local and fill in the values

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="MegaMark"

# Database — Configurație pentru pooler (IPv4) + direct connection (IPv6)
# DATABASE_URL — Connection pooling pentru Vercel (IPv4 compatible)
# Format: postgresql://postgres:[password]@aws-0-eu-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true
DATABASE_URL=

# DIRECT_URL — Direct connection pentru local și migrations (IPv6)
# Format: postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres
DIRECT_URL=

# Supabase Config
NEXT_PUBLIC_SUPABASE_URL=https://[your-project-ref].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=[your-anon-key]
SUPABASE_SERVICE_ROLE_KEY=[your-service-role-key]

# Pooler settings for Vercel compatibility (IPv4 → IPv6 bridge)
SUPABASE_POOLER_HOST=aws-0-eu-west-2.pooler.supabase.com
SUPABASE_POOLER_PORT=6543
SUPABASE_POOLER_MODE=transaction

# Auth (Supabase Auth)
NEXTAUTH_SECRET=[generate-with-openssl-rand-base64-32]
NEXTAUTH_URL=http://localhost:3000
# NEXTAUTH_URL=

# Stripe Payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SELLER=
STRIPE_PRICE_DEALER=
STRIPE_PRICE_ENTERPRISE=
STRIPE_PRICE_BOOST_FEATURED_7D=
STRIPE_PRICE_BOOST_FEATURED_14D=
# STRIPE_PRICE_BOOST_TOP_POSITION= (alias for 14d if needed)

# API Keys (future)
# MAPBOX_API_KEY=
# SENDGRID_API_KEY=